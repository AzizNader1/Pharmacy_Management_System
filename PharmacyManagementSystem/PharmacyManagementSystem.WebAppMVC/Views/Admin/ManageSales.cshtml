@model IEnumerable<PharmacyManagementSystem.Application.DTOs.SalesDTOs.GetSaleDto>
@{
    ViewData["Title"] = "Manage Sales";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <div>
            <strong>Success!</strong> @TempData["SuccessMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
        <div>
            <strong>Error!</strong> @TempData["ErrorMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <div>
            <strong>Info:</strong> @TempData["InfoMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-white m-0">Sales Analytics</h2>
        <p class="text-muted">Review all point-of-sale transactions and revenue details.</p>
    </div>
</div>

<div class="glass-panel">
    <div class="d-flex mb-4">
        <input type="text" class="form-control w-25 rounded-pill px-3" placeholder="Search Transactions..." />
    </div>

    <div class="table-responsive">
        @if (!Model.Any() || Model.FirstOrDefault()?.SaleId == 0)
        {
            <div class="text-center text-muted py-5">
                <h4>There is no data exists in the database right now.</h4>
            </div>
        }
        else
        {
            <table class="table table-dark table-hover bg-transparent text-white">
                <thead>
                    <tr>
                        <th class="border-0 border-bottom border-secondary text-muted px-3">Sale ID</th>
                        <th class="border-0 border-bottom border-secondary text-muted">User ID</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Date</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Items Count</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                        @foreach (var sale in Model)
                        {
                            <tr>
                                <td class="align-middle px-3 text-secondary">@sale.SaleId</td>
                                <td class="align-middle">@sale.UserId</td>
                                <td class="align-middle">@sale.SalesDate.ToString("g")</td>
                                <td class="align-middle">@(sale.SaleItems?.Count ?? 0)</td>
                                <td class="align-middle text-primary fw-bold">$@sale.TotalAmount</td>
                            </tr>
                        }
                </tbody>
            </table>
        }
    </div>
</div>
