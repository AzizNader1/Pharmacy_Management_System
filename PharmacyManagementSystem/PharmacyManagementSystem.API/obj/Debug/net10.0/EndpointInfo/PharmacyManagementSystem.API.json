                    "type": "string"
                  },
                  "Password": {
                    "maxLength": 100,
                    "minLength": 6,
                    "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).+$",
                    "type": "string"
                  },
