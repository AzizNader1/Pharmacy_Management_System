@model IEnumerable<PharmacyManagementSystem.Application.DTOs.MedicineDTOs.GetMedicineDto>
@{
    ViewData["Title"] = "Search Medicines";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <div>
            <strong>Success!</strong> @TempData["SuccessMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
        <div>
            <strong>Error!</strong> @TempData["ErrorMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="glass-panel mb-4 p-4">
    <form asp-action="SearchMedicines" method="post" class="m-0">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="text-white m-0">Inventory Catalog</h2>
            <div class="input-group w-50">
                <input type="text" name="search" class="form-control rounded-pill-start px-4 py-2 border-end-0" placeholder="Search by exact name..." />
                <button type="submit" class="btn btn-primary rounded-pill-end px-4 border-start-0">Search</button>
            </div>
        </div>
    </form>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @if (!Model.Any() || Model.FirstOrDefault()?.MedicineId == 0)
    {
        <div class="col-12 text-center text-muted py-5">
            <h4>No medicines found in catalog.</h4>
        </div>
    }
    @foreach (var med in Model)
    {
        <div class="col">
            <div class="glass-panel h-100 p-4">
                <h4 class="text-white">@med.Name</h4>
                <p class="text-muted mb-2">@med.GenericName - @med.Category</p>
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <span class="fs-4 text-primary fw-bold">$@med.MedicinePrice</span>
                    @if (med.ReorderLevel > 0)
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2">In Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-danger rounded-pill px-3 py-2">Out of Stock</span>
                    }
                </div>
                <small class="text-secondary mt-3 d-block">@med.Description</small>
            </div>
        </div>
    }
</div>
