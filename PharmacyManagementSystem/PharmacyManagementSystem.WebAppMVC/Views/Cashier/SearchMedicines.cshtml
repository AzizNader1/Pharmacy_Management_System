@model IEnumerable<PharmacyManagementSystem.Application.DTOs.MedicineDTOs.GetMedicineDto>
@{
    ViewData["Title"] = "Search Medicines";
}
<div class="glass-panel mb-4 p-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="text-white m-0">Inventory Catalog</h2>
        <div class="w-50">
            <input type="text" class="form-control rounded-pill px-4 py-2" placeholder="Search by name, category, or symptoms..." />
        </div>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted">No medicines found in catalog.</div>
    }
    @foreach (var med in Model)
    {
        <div class="col">
            <div class="glass-panel h-100 p-4">
                <h4 class="text-white">@med.Name</h4>
                <p class="text-muted mb-2">@med.GenericName - @med.Category</p>
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <span class="fs-4 text-primary fw-bold">$@med.MedicinePrice</span>
                    @if (med.ReorderLevel > 0)
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2">In Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-danger rounded-pill px-3 py-2">Out of Stock</span>
                    }
                </div>
                <small class="text-secondary mt-3 d-block">@med.Description</small>
            </div>
        </div>
    }
</div>
