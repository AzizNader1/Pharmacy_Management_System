@{
    ViewData["Title"] = "Cashier Dashboard";
}
<div class="row mb-4">
    <div class="col-12 text-center text-white">
        <h1 class="display-5 font-weight-bold">Welcome, Cashier</h1>
        <p class="lead text-muted">Select an operation below to get started.</p>
    </div>
</div>

<div class="row justify-content-center text-center">
    <div class="col-md-5 mb-4">
        <div class="glass-panel p-5 h-100 d-flex flex-column justify-content-center align-items-center">
            <h2 class="text-white">Point of Sale</h2>
            <p class="text-muted">Process new orders and checkout customers.</p>
            <a asp-action="Sales" class="btn btn-primary btn-lg mt-3 w-75 rounded-pill">Open POS</a>
        </div>
    </div>
    <div class="col-md-5 mb-4">
        <div class="glass-panel p-5 h-100 d-flex flex-column justify-content-center align-items-center">
            <h2 class="text-white">Medicines Catalog</h2>
            <p class="text-muted">Check inventory, prices, and availability.</p>
            <a asp-action="SearchMedicines" class="btn btn-primary btn-lg mt-3 w-75 rounded-pill">Search</a>
        </div>
    </div>
</div>
