@model PharmacyManagementSystem.Application.DTOs.SalesDTOs.CreateSaleDto
@{
    ViewData["Title"] = "Point of Sale";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <div>
            <strong>Success!</strong> @TempData["SuccessMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
        <div>
            <strong>Error!</strong> @TempData["ErrorMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <div>
            <strong>Info:</strong> @TempData["InfoMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Sales" method="post" id="posForm">
    <!-- Hidden Fields Required by CreateSaleDto -->
    <input type="hidden" asp-for="UserId" value="@Model.UserId" />
    <input type="hidden" asp-for="SalesDate" value="@Model.SalesDate.ToString("yyyy-MM-ddTHH:mm")" />

    <div class="row">
        <!-- Left Column: Items to Scan -->
        <div class="col-lg-8 mb-4">
            <div class="glass-panel h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="text-white m-0">Order Items</h3>
                    <div class="input-group w-50">
                        <select id="medicineLookup" class="form-select rounded-pill-start px-3 border-end-0 bg-dark text-white border-secondary" asp-items="ViewBag.Medicines">
                            <option value="">-- Select Medicine to Add --</option>
                        </select>
                        <button type="button" id="btnAddItem" class="btn btn-secondary rounded-pill-end px-3">Add</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-hover bg-transparent text-white" id="posTable">
                        <thead>
                            <tr>
                                <th class="border-0 border-bottom border-secondary text-muted px-3">Med ID</th>
                                <th class="border-0 border-bottom border-secondary text-muted">Name</th>
                                <th class="border-0 border-bottom border-secondary text-muted">Batch ID</th>
                                <th class="border-0 border-bottom border-secondary text-muted">Unit Price</th>
                                <th class="border-0 border-bottom border-secondary text-muted w-25">Qty</th>
                                <th class="border-0 border-bottom border-secondary text-muted text-end px-3"></th>
                            </tr>
                        </thead>
                        <tbody id="posTableBody">
                            <!-- Items go here dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Right Column: Order Summary -->
        <div class="col-lg-4 mb-4">
            <div class="glass-panel h-100 d-flex flex-column">
                <h3 class="text-white mb-4">Order Summary</h3>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Total Items:</span>
                    <span class="text-white fw-bold" id="totalItemsCount">0</span>
                </div>
                <hr class="border-secondary my-4" />
                <div class="d-flex justify-content-between mb-4 align-items-center">
                    <h4 class="text-white m-0">Total Amount</h4>
                    <div class="w-50">
                        <input asp-for="TotalAmount" id="totalAmountInput" type="number" step="0.01" class="form-control text-end text-primary fw-bold bg-dark border-secondary" value="0.00" readonly />
                    </div>
                </div>
                <div class="mt-auto">
                    <button type="button" id="btnCheckout" class="btn btn-primary w-100 py-3 rounded-pill fs-5 shadow">Complete Checkout</button>
                    <span asp-validation-for="TotalAmount" class="text-danger d-block mt-2 text-center"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var btnAdd = document.getElementById('btnAddItem');
            var lookupInput = document.getElementById('medicineLookup');
            var tbody = document.getElementById('posTableBody');
            var totalAmountInput = document.getElementById('totalAmountInput');
            var totalItemsCount = document.getElementById('totalItemsCount');
            var btnCheckout = document.getElementById('btnCheckout');
            var posForm = document.getElementById('posForm');

            // Auto-add when dropdown selection changes
            lookupInput.addEventListener('change', function () {
                if (lookupInput.value) {
                    btnAdd.click();
                }
            });

            btnAdd.addEventListener('click', function () {
                var id = lookupInput.value;
                if (!id) return;

                fetch('/Cashier/GetMedicineForPOS?medicineId=' + id)
                    .then(function (response) {
                        if (!response.ok) {
                            alert('Medicine not found in catalog.');
                            return null;
                        }
                        return response.json();
                    })
                    .then(function (data) {
                        if (!data) return;

                        if (data.batchId === 0) {
                            alert('Warning: No active batch exists for this medicine. It may be out of stock or expired.');
                            lookupInput.value = '';
                            return;
                        }

                        addRow(data);
                        lookupInput.value = '';
                        updateTotals();
                    })
                    .catch(function () {
                        alert('Error looking up the medicine details.');
                    });
            });

            function addRow(data) {
                var maxQty = data.availableQty || 1;
                var tr = document.createElement('tr');
                tr.innerHTML =
                    '<td class="align-middle px-3">' +
                        '<input type="hidden" class="med-id" value="' + data.medicineId + '" />' +
                        '<span class="text-secondary fw-bold">#' + data.medicineId + '</span>' +
                    '</td>' +
                    '<td class="align-middle fw-bold text-white">' + data.name + '</td>' +
                    '<td class="align-middle">' +
                        '<input type="hidden" class="batch-id" value="' + data.batchId + '" />' +
                        '<span class="text-secondary">#' + data.batchId + '</span>' +
                    '</td>' +
                    '<td class="align-middle">' +
                        '<input type="hidden" class="unit-price" value="' + data.price + '" />' +
                        '<span class="text-info fw-bold">$' + parseFloat(data.price).toFixed(2) + '</span>' +
                    '</td>' +
                    '<td class="align-middle">' +
                        '<input type="number" min="1" max="' + maxQty + '" class="form-control form-control-sm text-white bg-dark border-secondary item-qty" value="1" style="width:90px;" />' +
                        '<small class="text-muted d-block" style="font-size:0.7rem;">Max: ' + maxQty + '</small>' +
                    '</td>' +
                    '<td class="align-middle text-end px-3">' +
                        '<button type="button" class="btn btn-sm btn-outline-danger px-2 py-0 border-0 fs-5 btn-remove shadow-none" title="Remove Item">&times;</button>' +
                    '</td>';

                var qtyInput = tr.querySelector('.item-qty');

                qtyInput.addEventListener('input', function () {
                    var val = parseInt(this.value) || 1;
                    if (val > maxQty) {
                        this.value = maxQty;
                        alert('Cannot exceed available stock of ' + maxQty + ' units for this medicine.');
                    }
                    if (val < 1) this.value = 1;
                    updateTotals();
                });

                tr.querySelector('.btn-remove').addEventListener('click', function () {
                    tr.remove();
                    updateTotals();
                });

                tbody.appendChild(tr);
            }

            function updateTotals() {
                var currentTotal = 0;
                var itemsNum = 0;
                var rows = tbody.querySelectorAll('tr');

                rows.forEach(function (row, index) {
                    // Assign names for ASP.NET MVC model binding
                    row.querySelector('.med-id').name = 'saleItems[' + index + '].MedicineId';
                    row.querySelector('.batch-id').name = 'saleItems[' + index + '].BatchId';
                    row.querySelector('.unit-price').name = 'saleItems[' + index + '].UnitPrice';
                    row.querySelector('.item-qty').name = 'saleItems[' + index + '].ItemQuantity';

                    var price = parseFloat(row.querySelector('.unit-price').value) || 0;
                    var qty = parseInt(row.querySelector('.item-qty').value) || 0;

                    currentTotal += (price * qty);
                    itemsNum += qty;
                });

                totalAmountInput.value = currentTotal.toFixed(2);
                totalItemsCount.innerText = itemsNum;
            }

            btnCheckout.addEventListener('click', function () {
                updateTotals();
                if (tbody.querySelectorAll('tr').length === 0) {
                    alert('Please add at least one item before checking out.');
                    return;
                }
                posForm.submit();
            });
        });
    </script>
}
