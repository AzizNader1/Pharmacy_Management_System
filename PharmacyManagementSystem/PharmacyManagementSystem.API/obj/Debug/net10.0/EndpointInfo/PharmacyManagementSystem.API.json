  "components": {
    "schemas": {
      "CreateBatchDto": {
        "required": [
          "batchNumber",
          "batchQuantity",
          "category",
          "expiryDate",
          "medicineId",
          "purchasePrice"
        ],
        "type": "object",
        "properties": {
          "batchNumber": {
            "maxLength": 10,
            "minLength": 4,
            "pattern": "^[A-Za-z0-9]+$",
            "type": "string"
          },
          "expiryDate": {
            "type": "string",
            "format": "date"
          },
          "batchQuantity": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "purchasePrice": {
            "maximum": 999999.99,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "category": {
            "$ref": "#/components/schemas/MedicineCategories"
          },
          "medicineId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateMedicineDto": {
        "required": [
          "category",
          "genericName",
          "medicinePrice",
          "name",
          "reorderLevel"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 2,
            "pattern": "^[a-zA-Z0-9\\s\\-]+$",
            "type": "string"
          },
          "genericName": {
            "maxLength": 200,
            "minLength": 2,
            "type": "string"
          },
          "description": {
            "maxLength": 1000,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "medicinePrice": {
            "maximum": 999999.99,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "reorderLevel": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "category": {
            "$ref": "#/components/schemas/MedicineCategories"
          }
        },
        "additionalProperties": false
      },
      "CreateSaleDto": {
        "required": [
          "salesDate",
          "totalAmount",
          "userId"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "salesDate": {
            "type": "string",
            "format": "date"
          },
          "totalAmount": {
            "maximum": 99999999.99,
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateSaleItemDto": {
        "required": [
          "batchId",
          "itemQuantity",
          "medicineId",
          "saleId",
          "unitPrice"
        ],
        "type": "object",
        "properties": {
          "saleId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "medicineId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "batchId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
