@model PharmacyManagementSystem.Application.DTOs.UserDTOs.LoginRequestDto
@{
    ViewData["Title"] = "Login";
}
@if (ViewBag.ErrorMessage != null)
{
    <div class="login-error-banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
        </svg>
        <span>@ViewBag.ErrorMessage</span>
    </div>
}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="glass-panel text-center">
            <h2 class="mb-4 text-white">Welcome Back</h2>
            <form asp-action="Login" method="post">
                <div class="form-floating mb-3 text-start">
                    <input asp-for="UserName" class="form-control" placeholder="UserName" />
                    <label asp-for="UserName" class="text-secondary">UserName</label>
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3 text-start">
                    <input asp-for="Email" type="email" class="form-control" placeholder="Email Address" />
                    <label asp-for="Email" class="text-secondary">Email</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-4 text-start">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    <label asp-for="Password" class="text-secondary">Password</label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fs-5 rounded-pill">Sign In</button>
            </form>
            <div class="mt-4">
                <p class="text-muted">Don't have an account? <a asp-action="Signup" class="text-info text-decoration-none">Sign up</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}