@{
    ViewData["Title"] = "Sales Reports";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-white m-0">Sales & Financials</h2>
    <div class="btn-group" role="group">
        <button type="button" class="btn btn-primary px-4">Today</button>
        <button type="button" class="btn btn-outline-primary px-4">Weekly</button>
        <button type="button" class="btn btn-outline-primary px-4">Monthly</button>
        <button type="button" class="btn btn-outline-primary px-4">Quarterly</button>
    </div>
</div>

<div class="row mb-5">
    <!-- Chart placeholder -->
    <div class="col-12">
        <div class="glass-panel p-4" style="min-height: 350px; display: flex; justify-content: center; align-items: center;">
            <div class="text-center w-100">
                <h4 class="text-muted mb-3 text-start">Revenue Chart</h4>
                <div class="bg-dark rounded-4 d-flex justify-content-center align-items-center" style="height: 250px; border: 2px dashed rgba(255,255,255,0.1)">
                    <p class="text-muted m-0"><i class="text-primary fs-4">📊</i> Chart visualization library goes here.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="glass-panel">
    <h4 class="text-white mb-4">Recent Transactions</h4>
    <div class="table-responsive">
        <table class="table table-dark table-hover bg-transparent text-white m-0">
            <thead>
                <tr>
                    <th class="border-0 border-bottom border-secondary text-muted px-3">Date & Time</th>
                    <th class="border-0 border-bottom border-secondary text-muted">Order ID</th>
                    <th class="border-0 border-bottom border-secondary text-muted">Amount</th>
                    <th class="border-0 border-bottom border-secondary text-muted text-end px-3">Cashier</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="align-middle px-3">Today, 2:30 PM</td>
                    <td class="align-middle text-secondary">ORD-00921</td>
                    <td class="align-middle text-success fw-bold">+$24.30</td>
                    <td class="align-middle text-end px-3">John Doe</td>
                </tr>
                <tr>
                    <td class="align-middle px-3">Today, 1:15 PM</td>
                    <td class="align-middle text-secondary">ORD-00920</td>
                    <td class="align-middle text-success fw-bold">+$12.50</td>
                    <td class="align-middle text-end px-3">Jane Smith</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
