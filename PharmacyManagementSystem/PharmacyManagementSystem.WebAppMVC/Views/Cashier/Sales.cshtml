@model PharmacyManagementSystem.Application.DTOs.SalesDTOs.CreateSaleDto
@{
    ViewData["Title"] = "Point of Sale";
}

<form asp-action="Sales" method="post">
    <!-- Hidden Fields Required by CreateSaleDto -->
    <input type="hidden" asp-for="UserId" value="1" /> <!-- Example Cashier ID -->
    <!-- The Date is auto-populated in JS or backend usually, but here is field -->
    <input type="hidden" asp-for="SalesDate" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />

    <div class="row">
        <!-- Left Column: Items to Scan -->
        <div class="col-lg-8 mb-4">
            <div class="glass-panel h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="text-white m-0">Order Items</h3>
                    <input type="text" class="form-control w-50" placeholder="Scan Barcode / Search MedicineId" />
                </div>
                <!-- 
                   Each row represents a PharmacyManagementSystem.Application.DTOs.SalesItemsDTOs.CreateSaleItemDto.
                   JavaScript would ideally construct the array to post. We setup data to show we match the fields exactly.
                -->
                <div class="table-responsive">
                    <table class="table table-dark table-hover bg-transparent text-white">
                        <thead>
                            <tr>
                                <th class="border-0 border-bottom border-secondary text-muted px-3">Medicine ID</th>
                                <th class="border-0 border-bottom border-secondary text-muted">Batch ID</th>
                                <th class="border-0 border-bottom border-secondary text-muted">UnitPrice</th>
                                <th class="border-0 border-bottom border-secondary text-muted">ItemQuantity</th>
                                <th class="border-0 border-bottom border-secondary text-muted"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Demo Row representing a CreateSaleItemDto -->
                            <tr>
                                <td class="align-middle px-3">
                                    <input type="number" name="SaleItems[0].MedicineId" class="form-control form-control-sm" value="12" readonly />
                                </td>
                                <td class="align-middle">
                                    <input type="number" name="SaleItems[0].BatchId" class="form-control form-control-sm w-75" value="105" readonly />
                                </td>
                                <td class="align-middle">
                                    <input type="number" step="0.01" name="SaleItems[0].UnitPrice" class="form-control form-control-sm w-75" value="5.00" readonly />
                                </td>
                                <td class="align-middle">
                                    <input type="number" name="SaleItems[0].ItemQuantity" class="form-control form-control-sm w-50" value="2" />
                                </td>
                                <td class="align-middle"><button type="button" class="btn btn-sm btn-outline-danger px-2 py-0 border-0 fs-5">&times;</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Right Column: Order Summary -->
        <div class="col-lg-4 mb-4">
            <div class="glass-panel h-100 d-flex flex-column">
                <h3 class="text-white mb-4">Order Summary</h3>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal (calculated later)</span>
                    <span class="text-white"></span>
                </div>
                <hr class="border-secondary my-4" />
                <div class="d-flex justify-content-between mb-4 align-items-center">
                    <h4 class="text-white m-0">TotalAmount</h4>
                    <div class="w-50">
                        <input asp-for="TotalAmount" type="number" step="0.01" class="form-control text-end text-primary fw-bold" value="10.00" readonly />
                    </div>
                </div>
                <div class="mt-auto">
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fs-5">Complete Checkout</button>
                    <span asp-validation-for="TotalAmount" class="text-danger d-block mt-2 text-center"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
