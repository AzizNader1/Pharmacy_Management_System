@model PharmacyManagementSystem.Application.DTOs.BatchDTOs.GetBatchDto
@{
    ViewData["Title"] = "Delete Batch";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="glass-panel text-center border-danger" style="border-width: 2px;">
            <div class="mb-4 text-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-exclamation-triangle-fill" viewBox="0 0 16 16">
                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                </svg>
            </div>
            <h2 class="mb-3 text-white">Delete Batch?</h2>
            <p class="text-muted mb-4">Are you sure you want to permanently delete Batch <strong class="text-white">@Model.BatchNumber</strong> (Medicine ID: @Model.MedicineId)? This action cannot be undone.</p>
            
            <div class="p-3 mb-4 rounded bg-dark bg-opacity-50 text-start text-white border-start border-danger border-4">
                <div class="mb-1"><strong class="text-muted text-uppercase small">Quantity:</strong> @Model.BatchQuantity units</div>
                <div class="mb-1"><strong class="text-muted text-uppercase small">Expiry Date:</strong> @Model.ExpiryDate.ToShortDateString()</div>
                <div><strong class="text-muted text-uppercase small">Price:</strong> $@Model.PurchasePrice</div>
            </div>

            <form asp-action="DeleteBatch" method="post">
                <input type="hidden" asp-for="BatchId" />
                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="ManageBatchs" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-bold">Cancel</a>
                    <button type="submit" class="btn btn-danger px-4 py-2 rounded-pill fw-bold shadow">Yes, Delete Batch</button>
                </div>
            </form>
        </div>
    </div>
</div>
