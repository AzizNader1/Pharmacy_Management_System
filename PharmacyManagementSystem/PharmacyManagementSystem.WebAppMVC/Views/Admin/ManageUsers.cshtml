@model IEnumerable<PharmacyManagementSystem.Application.DTOs.UserDTOs.GetUserDto>
@{
    ViewData["Title"] = "Manage Users";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <div>
            <strong>Success!</strong> @TempData["SuccessMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
        <div>
            <strong>Error!</strong> @TempData["ErrorMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show d-flex align-items-center mb-4 shadow-sm" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <div>
            <strong>Info:</strong> @TempData["InfoMessage"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-white m-0">User Accounts</h2>
        <p class="text-muted">Manage system access for cashiers and administrators.</p>
    </div>
</div>

<div class="glass-panel">
    <div class="d-flex mb-4">
        <input type="text" class="form-control w-25 rounded-pill px-3" placeholder="Search Users..." />
    </div>

    <div class="table-responsive">
        @if (!Model.Any() || Model.FirstOrDefault()?.UserId == 0)
        {
            <div class="text-center text-muted py-5">
                <h4>There is no data exists in the database right now.</h4>
            </div>
        }
        else
        {
            <table class="table table-dark table-hover bg-transparent text-white">
                <thead>
                    <tr>
                        <th class="border-0 border-bottom border-secondary text-muted px-3">User ID</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Username</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Full Name</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Email</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Phone</th>
                        <th class="border-0 border-bottom border-secondary text-muted">Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="align-middle px-3 text-secondary">@user.UserId</td>
                            <td class="align-middle fw-bold text-white">@user.UserName</td>
                            <td class="align-middle">@user.FullName</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="align-middle">@user.PhoneNumber</td>
                            <td class="align-middle">
                                @if (user.UserRole.ToString() == "Admin")
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2 border border-danger bg-opacity-25 text-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-info rounded-pill px-3 py-2 border border-info bg-opacity-25 text-info">Cashier</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
